@model IEnumerable<CetBookStore.Models.CartItem>

<h2>My Cart</h2>

<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Quantity</th>
        <th>Price</th>
        <th>Total</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Book.Title</td>
            <td>@item.Quantity</td>
            <td>@item.Price.ToString("C2")</td>
            <td>@((item.Quantity * item.Price).ToString("C2"))</td>
        </tr>
    }
    </tbody>
</table>

<div class="text-end mt-3">
    <h4>Total: @Model.Sum(x => x.Quantity * x.Price).ToString("C2")</h4>
    
    <form asp-controller="Cart" asp-action="Purchase" method="post">
        <button type="submit" class="btn btn-success btn-lg">
            Purchase
        </button>
    </form>
</div>