@model CetBookStore.Models.Book

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Book</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Author)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Author)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Publisher)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Publisher)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PageCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PageCount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsInSale)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsInSale)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PreviousPrice)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PreviousPrice)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PublicationDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PublicationDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Category.Name)
        </dd>
    </dl>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        @if (User.Identity.IsAuthenticated)
        {
            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="row g-3 align-items-center">
                <input type="hidden" name="bookId" value="@Model.Id" />
                <div class="col-auto">
                    <label class="col-form-label">Quantity:</label>
                </div>
                <div class="col-auto">
                    <input type="number" name="quantity" value="1" min="1" class="form-control" style="width: 80px;" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-cart-plus"></i> Add to Cart
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                Please <a asp-area="Identity" asp-page="/Account/Login">login</a> to add this book to your cart.
            </div>
        }
    </div>
</div>


<div class="row d-flex justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-0 border" style="background-color: #f0f2f5;">
            <div class="card-body p-4">
                <div data-mdb-input-init class="form-outline mb-4">
                    <form asp-action="CommentCreate" >
                        <input type="text" name="UserName" class="form-control" placeholder="Who you are .." />
                        <input type="text" name="Content" class="form-control" placeholder="Type comment..." />
                        <input type="hidden" name="BookId" value="@Model.Id" />
                        <button class="form-label" type="submit">+ Add a note</button>
                    
                    </form>
                </div>
   @foreach (var comment in Model.Comments)
                {
                    <div class="card mb-4">
                        <div class="card-body">
                            <p>@comment.Content</p>

                            <div class="d-flex justify-content-between">
                                <div class="d-flex flex-row align-items-center">
                                 
                                    <p class="small mb-0 ms-2">@comment.UserName</p>
                                </div>
                                <div class="d-flex flex-row align-items-center">
                                    <p class="small text-muted mb-0">@comment.CreatedDate.ToShortDateString()</p>
                          
                                </div>
                            </div>
                        </div>
                    </div>


                }

            </div>
        </div>
    </div>
</div>







@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}