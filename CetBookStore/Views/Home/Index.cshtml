@model CetBookStore.ViewModels.HomePageViewModel
@{
    ViewData["Title"] = "Home Page";
}


  <div class="container mt-5">
    <h2 class="mb-4"> Most Commented Books </h2>
    <div class="row g-4">

    @foreach (var book in Model.MostCommenteds)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <img src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=400" class="card-img-top" alt="@book.Title">
                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="card-text text-muted">@book.Author</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h5 mb-0">@book.Price.ToString("C2")</span>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between bg-light">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="bookId" value="@book.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-sm">Add to Cart</a>
                    }
                    <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-heart"></i></button>
                </div>
            </div>
        </div>
    
    
    }
    </div>
  </div>

  <hr />

